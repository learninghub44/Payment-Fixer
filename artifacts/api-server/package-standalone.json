    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.31.10",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.9",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
